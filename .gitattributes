# Auto detect text files and perform LF normalization
* text=auto

# JavaScript
*.js text eol=lf
*.cjs text eol=lf
*.mjs text eol=lf

# TypeScript declarations
*.d.ts text eol=lf

# Config files
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Markdown
*.md text eol=lf diff=markdown

# Shell scripts
*.sh text eol=lf

# HTML/CSS
*.html text eol=lf
*.css text eol=lf

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg text eol=lf

# Lock files
package-lock.json -diff
